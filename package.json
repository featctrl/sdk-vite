{
  "name": "@featctrl/vite",
  "version": "0.0.0",
  "description": "FeatCtrl Vite SDK — SSE client for Node.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/featctrl/sdk-vite.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
