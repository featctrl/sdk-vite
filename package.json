    "test:integration": "vitest run tests/integration"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.0",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22 <25"
  }
}
